{
  "name": "benchmarks-ab-demo",
  "version": "0.1.0",
  "private": true,
  "description": "A reproducible A/B benchmark for Codex repository work with and without Vertex Palace.",
  "type": "module",
  "bin": {
    "vertex-palace-benchmark": "./bin/benchmark.mjs"
  },
  "scripts": {
    "benchmark": "node ./bin/benchmark.mjs",
    "demo:prepare": "node ./bin/benchmark.mjs prepare",
    "test": "node --test test/*.test.mjs",
    "test:fixture": "node ./scripts/check-fixture.mjs",
    "analysis:pilot": "node ./analysis/paired-analysis.mjs --manifest results/manifest.json --out results/pilot/analysis.json",
    "analysis:adaptive": "node ./analysis/paired-analysis.mjs --manifest results/adaptive-pilot-v2.2/manifest.json --out results/adaptive-pilot-v2.2/analysis.json",
    "analysis:adaptive:v2": "node ./analysis/paired-analysis.mjs --manifest results/adaptive-pilot/manifest.json --out results/adaptive-pilot/analysis.json",
    "analysis:adaptive:v2.1": "node ./analysis/paired-analysis.mjs --manifest results/adaptive-pilot-v2.1/manifest.json --out results/adaptive-pilot-v2.1/analysis.json",
    "analysis:control-first:v3": "node ./analysis/paired-analysis.mjs --manifest results/control-first-v3/manifest.json --out results/control-first-v3/analysis.json",
    "analysis:control-first:v3:candidate": "node ./analysis/paired-analysis.mjs --manifest results/control-first-v3-candidate/manifest.json --out results/control-first-v3-candidate/analysis.json",
    "verify:analysis:adaptive": "node ./scripts/verify-adaptive-analysis.mjs",
    "analysis:power": "node ./analysis/power-analysis.mjs",
    "audit:results": "node ./scripts/audit-results.mjs",
    "audit:adaptive:v2": "node ./scripts/audit-results.mjs results/adaptive-pilot/manifest.json --allow-incomplete",
    "audit:adaptive:v2.1": "node ./scripts/audit-results.mjs results/adaptive-pilot-v2.1/manifest.json --allow-incomplete",
    "audit:adaptive:v2.2": "node ./scripts/audit-results.mjs results/adaptive-pilot-v2.2/manifest.json --allow-incomplete",
    "audit:control-first:v3": "node ./scripts/audit-results.mjs results/control-first-v3/manifest.json --allow-incomplete",
    "audit:control-first:v3:candidate": "node ./scripts/audit-results.mjs results/control-first-v3-candidate/manifest.json --allow-incomplete",
    "gate:control-first:v3": "node ./scripts/verify-control-first-v3-release.mjs",
    "check:release-ready": "npm run check && npm run gate:control-first:v3",
    "freeze:control-first:v3": "node ./scripts/prepare-control-first-v3-freeze.mjs",
    "v4:plan": "node ./bin/benchmark.mjs v4-plan --write",
    "v4:gate": "node ./bin/benchmark.mjs v4-gate",
    "check:v4-prep": "node ./scripts/verify-v4-preparation.mjs",
    "reveal:control-first:v3": "node ./scripts/reveal-control-first-v3.mjs --write",
    "verify:reveal:control-first:v3": "node ./scripts/reveal-control-first-v3.mjs --verify",
    "run:control-first:v3:candidate": "node ./scripts/run-control-first-v3-candidate.mjs",
    "run:real-repository:v4": "node ./scripts/run-real-repository-v4.mjs",
    "dry-run:real-repository:v4": "node ./scripts/run-real-repository-v4.mjs --prepare-only",
    "prepare:real-repository:v4:profile": "node ./scripts/prepare-real-repository-v4-profile.mjs",
    "self-test:real-repository:v4:evaluator": "node ./scripts/self-test-v4-private-evaluator.mjs",
    "freeze:real-repository:v4:execution": "node ./scripts/prepare-real-repository-v4-execution.mjs",
    "publish:retry-cost:real-repository:v4": "node ./scripts/publish-real-repository-v4-retry-cost.mjs --write",
    "verify:retry-cost:real-repository:v4": "node ./scripts/publish-real-repository-v4-retry-cost.mjs --verify",
    "reveal:real-repository:v4": "node ./scripts/reveal-real-repository-v4.mjs --write",
    "verify:reveal:real-repository:v4": "node ./scripts/reveal-real-repository-v4.mjs --verify",
    "analysis:real-repository:v4": "node ./analysis/real-repository-v4-analysis.mjs",
    "verify:analysis:real-repository:v4": "node ./analysis/real-repository-v4-analysis.mjs --verify",
    "publish:mechanism-audit:real-repository:v4": "node ./scripts/publish-real-repository-v4-mechanism-audit.mjs --write",
    "verify:mechanism-audit:real-repository:v4": "node ./scripts/publish-real-repository-v4-mechanism-audit.mjs --verify",
    "check:real-repository:v4": "npm run verify:retry-cost:real-repository:v4 && npm run verify:reveal:real-repository:v4 && npm run verify:analysis:real-repository:v4 && npm run verify:mechanism-audit:real-repository:v4",
    "publish:run": "node ./scripts/publish-run.mjs",
    "check": "npm run test && npm run test:fixture && npm run audit:results && npm run audit:adaptive:v2 && npm run audit:adaptive:v2.1 && npm run audit:adaptive:v2.2 && npm run audit:control-first:v3 && npm run audit:control-first:v3:candidate && npm run verify:analysis:adaptive && npm run check:v4-prep && npm run check:real-repository:v4"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "vertex-palace": "0.3.0"
  },
  "license": "MIT"
}
